# Database Configuration
# For SQLiteCloud (production) - provide your connection string
SQLALCHEMY_DATABASE_URL=sqlitecloud://your-api-key@your-endpoint:8860/your-database.sqlite

# Server Configuration
SECRET_KEY=your-secret-key
ALGORITHM=HS256
TOKEN_EXPIRATION=7
VERSION=1.0.0
NODE_ENV=production

# Test Mode
# Set to true to use local SQLite database and create default admin user (admin/admin)
# Leave false or empty for production mode
TEST=false

# Command to run
COMMAND=uvicorn main:app --host 0.0.0.0 --port 8000


