# Database Configuration
DB_TYPE=sqlite  # Options: sqlite, sqlitecloud
SQLALCHEMY_DATABASE_URL=sqlite:///./finalisthub.db

# For SQLiteCloud (production)
# SQLALCHEMY_DATABASE_URL=sqlitecloud://your-api-key@your-endpoint:8860/your-database.sqlite

# Server Configuration
SECRET_KEY=your-secret-key
ALGORITHM=HS256
TOKEN_EXPIRATION=7
VERSION=1.0.0
NODE_ENV=production

# Test Mode (creates default admin user: admin/admin)
TEST_MODE=false

# Command to run
COMMAND=uvicorn main:app --host 0.0.0.0 --port 8000


